# ローカル開発用の環境変数サンプル。
# 実際の値を入れて `.env` にコピーしてください(.env はコミットされません)。
# Nuxt は NUXT_ 接頭辞の変数を runtimeConfig に流し込みます。

# --- サーバー専用 ---
NUXT_GEMINI_API_KEY=
NUXT_GEMINI_MODEL=gemini-1.5-flash
NUXT_VAPID_PUBLIC=
NUXT_VAPID_PRIVATE=
NUXT_VAPID_SUBJECT=mailto:you@example.com

# 初期ロール判定用(このメールで初回ログインした人を自動で昇格)
NUXT_SUPERUSER_EMAIL=
NUXT_OWNER_EMAIL=

# --- クライアントにも渡る(public) ---
# Firebase の公開設定を JSON 文字列で1行に
NUXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"","authDomain":"","projectId":"","appId":""}
# Web Push 購読用の公開鍵
NUXT_PUBLIC_VAPID_PUBLIC=

# --- firebase-admin 用(ローカルのみ) ---
# サービスアカウント鍵の絶対パス。Cloud Run 上では不要(実行SAを自動使用)。
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
